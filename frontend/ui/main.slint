
import { StandardButton, Button, VerticalBox } from "std-widgets.slint";

import { Theme } from "./theme.slint";

// Import the global app logic, and then export it so build.rs picks it up, too.
import { AppLogic } from "./globals.slint";
export { AppLogic }

// Components making up the main UI 
import { EmulatorRegisters, Registers } from "./emu/registers.slint";
export { EmulatorRegisters }

import { EmulatorState, State } from "./emu/state.slint";
export { EmulatorState }

import { HardwareState, Hardware } from "./emu/hardware.slint";
export { HardwareState }

import { AppControls } from "./emu/controls.slint";
import { State } from "./emu/state.slint";

import { MemoryView, MemoryViewData } from "./emu/memory.slint";
export { MemoryView, MemoryViewData }

import { SettingsWindow } from "./settings.slint";
export { SettingsWindow }


export component MainWindow inherits Window {
    title: "eightyeighty — Intel 8080 Emulator";
    preferred-width: 1200px;
    preferred-height: 800px;
    background: Theme.app-background;

    MenuBar {
        Menu {
            title: @tr("File");
            MenuItem {
                title: @tr("Settings");
                activated => { AppLogic.cb-show-settings(); }
            }
            MenuItem {
                title: @tr("Exit");
                activated => { AppLogic.cb-exit(); }
            }
        }
        Menu {
            title: @tr("CPU");
            MenuItem {
                title: @tr("Memory");
                activated => { AppLogic.cb-show-memory(); }
            }
            MenuItem {
                title: @tr("Insert ROM");
                activated => { AppLogic.cb-insert-rom(); }
            }
            MenuItem {
                title: @tr("Reset");
            }
        }
    }


    GridLayout {
        
        Rectangle {
            col: 0;
            row: 0;
            rowspan: 5;
            width: 60%;
            height: 100%;
            background: red;
            Text {
                text: "Display";
            }            
        }
        Rectangle {
            col: 1;
            row: 0;
            min-height: 20px;
        
            vertical-stretch: 1;
            
            AppControls { }
        }
        Rectangle {
            col: 1;
            row: 1;
            min-height: 20px;
            vertical-stretch: 1;

            State {}
    
        }
        Rectangle {
            col: 1;
            row: 2;
            min-height: 70px;
            vertical-stretch: 1;
            Hardware {}           
        }
        Rectangle {
            col: 1;
            row: 3;
            height: 25%;
            
            vertical-stretch: 1;
            Registers {}             
        }
        Rectangle {
            col: 1;
            row: 4;
            height: 25%;
            background: #385769;

            vertical-stretch: 1;
            Text {
                text: "ROM Information";
            }                         
        }
    }
}

